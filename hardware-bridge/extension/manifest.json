{
  "manifest_version": 3,
  "name": "OEM Hardware Bridge",
  "version": "1.0.1",
  "description": "Secure bridge for detecting USB hardware information for KeyGate",
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://localhost:8443/*",
    "http://127.0.0.1:8080/*",
    "https://127.0.0.1:8443/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "https://localhost:8443/*",
        "http://127.0.0.1:8080/*",
        "https://127.0.0.1:8443/*"
      ],
      "js": ["page-api.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": [
        "http://localhost:8080/*",
        "https://localhost:8443/*",
        "http://127.0.0.1:8080/*",
        "https://127.0.0.1:8443/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
