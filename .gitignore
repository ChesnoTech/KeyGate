# ── Credentials & Environment ─────────────────────────────
.env
.env.local
.env.production

# ── SSL Certificates (never commit private keys) ─────────
ssl/*.key
ssl/*.crt
ssl/*.pem

# ── Database (root-level copy is obsolete; use FINAL_PRODUCTION_SYSTEM/database/)
/database/

# ── Database Backups ──────────────────────────────────────
/backups/
*.sql.gz

# ── Logs ──────────────────────────────────────────────────
logs/
*.log

# ── graphify output (auto-rebuilt by post-commit hook, AST-only, no LLM) ─
# Don't commit 12MB+ artifacts — every dev rebuilds locally on first commit.
**/graphify-out/

# ── Uploaded client artifacts (per-instance, regenerated at runtime) ──
FINAL_PRODUCTION_SYSTEM/uploads/client-resources/

# ── Installer runtime artifacts (per-host, never committed) ────────
FINAL_PRODUCTION_SYSTEM/install/install.log
FINAL_PRODUCTION_SYSTEM/install/.progress.json

# ── PHP Dependencies (managed by Composer) ────────────────
FINAL_PRODUCTION_SYSTEM/vendor/

# ── C# Build Artifacts ───────────────────────────────────
hardware-bridge/native-app/bin/
hardware-bridge/native-app/obj/
*.exe
*.dll
*.pdb

# ── WebRootAfterInstall (deployment artifact, not source) ─
WebRootAfterInstall/

# ── Vision Tests (screenshots contain credentials) ───────
vision_tests/

# ── Claude Session Data ──────────────────────────────────
.claude/
!.claude/settings.json
!.claude/launch.json

# ── IDE & OS ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Test & Debug Files ───────────────────────────────────
test_*.php
test_*.html
test_*.ps1
full_system_regression_test.ps1
test-security-features.ps1

# ── Backup Files ─────────────────────────────────────────
*.backup
*.bak
*.old
*.orig

# ── Setup Lock (created after installation) ──────────────
setup.lock
FINAL_PRODUCTION_SYSTEM/setup.lock

# ── Build & Temp ─────────────────────────────────────────
*.tmp
*.temp
*.cache
*.zip
*.tar.gz
nul
